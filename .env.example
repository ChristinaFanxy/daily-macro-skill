# Daily Macro Skill - API Keys Configuration
# Copy this file to .env and fill in your API keys

# FRED API (Federal Reserve Economic Data)
# Get your key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Finnhub API (Real-time commodities and news)
# Get your key at: https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_api_key_here

# Twelve Data API (Backup for commodities)
# Get your key at: https://twelvedata.com/register
TWELVE_DATA_API_KEY=your_twelve_data_api_key_here

# NewsAPI (Financial news search)
# Get your key at: https://newsapi.org/register
NEWSAPI_KEY=your_newsapi_key_here

# Alpha Vantage API (Backup for precious metals)
# Get your key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY_1=your_alpha_vantage_key_here
ALPHA_VANTAGE_KEY_2=your_alpha_vantage_backup_key_here
